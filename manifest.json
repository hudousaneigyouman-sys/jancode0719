:root{font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;color:#0f172a;background:#f1f5f9;--primary:#0f766e;--primary-dark:#115e59;--line:#cbd5e1}*{box-sizing:border-box}body{margin:0;padding-bottom:90px}button,input,textarea{font:inherit}button{cursor:pointer}.app-header{position:sticky;top:0;z-index:10;display:flex;justify-content:space-between;align-items:center;padding:18px 16px;color:#fff;background:#0f172a}.app-header h1{margin:0;font-size:1.4rem}.app-header p{margin:4px 0 0;font-size:.82rem;opacity:.82}main{max-width:760px;margin:0 auto;padding:14px}.card{background:#fff;border-radius:18px;padding:16px;margin-bottom:14px;box-shadow:0 8px 24px rgba(15,23,42,.06)}label{display:block;margin:12px 0 6px;font-weight:800}label strong{color:#b91c1c;font-size:.75rem;margin-left:6px}input,textarea{width:100%;border:1px solid var(--line);border-radius:12px;padding:14px;background:#fff;font-size:16px}input:focus,textarea:focus{outline:3px solid rgba(15,118,110,.18);border-color:var(--primary)}.search-row,.voice-row{display:grid;grid-template-columns:1fr auto;gap:9px;align-items:stretch}.search-row .primary{min-width:84px}.voice-btn{border:0;border-radius:12px;padding:12px 14px;font-weight:800;background:#dbeafe;color:#1e40af;white-space:nowrap}.voice-btn.listening{background:#fee2e2;color:#991b1b}.voice-btn:disabled{opacity:.55}.help,.status{color:#475569;font-size:.88rem;line-height:1.5}.row-actions,.dialog-actions{display:flex;gap:10px;margin-top:12px}.section-title-row{display:flex;justify-content:space-between;align-items:center}h2{margin:0;font-size:1.1rem}.badge{background:#e2e8f0;padding:5px 9px;border-radius:999px;font-size:.8rem}.item-list{display:grid;gap:9px;margin-top:12px}.item{display:grid;grid-template-columns:1fr auto;gap:8px;align-items:stretch;border:1px solid #e2e8f0;background:#fff;border-radius:14px;padding:8px}.item-main{display:flex;flex-direction:column;align-items:flex-start;text-align:left;border:0;background:transparent;padding:7px;min-width:0}.item-name{font-weight:800;margin-bottom:4px}.item-code{color:#475569;font-size:.88rem;word-break:break-all}.edit-button{border:0;border-radius:10px;background:#e0f2fe;color:#075985;font-weight:800;padding:8px 12px}.empty{text-align:center;color:#64748b;padding:28px 10px}.primary,.ghost,.danger{border:0;border-radius:12px;padding:12px 14px;font-weight:800}.primary{background:var(--primary);color:#fff}.primary:hover{background:var(--primary-dark)}.ghost{background:#e2e8f0;color:#1e293b}.danger{background:#fee2e2;color:#991b1b}.small{padding:9px 11px;font-size:.82rem}.full{width:100%}.fab{position:fixed;right:18px;bottom:90px;width:58px;height:58px;border-radius:50%;border:0;background:var(--primary);color:#fff;font-size:2rem;box-shadow:0 12px 28px rgba(15,118,110,.35);z-index:12}dialog{border:0;border-radius:20px;padding:0;width:min(94vw,560px);box-shadow:0 24px 60px rgba(0,0,0,.28)}dialog::backdrop{background:rgba(15,23,42,.58)}.dialog-card{padding:18px}.dialog-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}.icon-btn{border:0;background:#e2e8f0;width:38px;height:38px;border-radius:50%;font-size:1.4rem}details{margin-top:14px;padding:10px 12px;border:1px solid #e2e8f0;border-radius:12px}summary{font-weight:800;cursor:pointer}.error{color:#b91c1c;min-height:1.2em}.split{justify-content:space-between}.confirm-label{margin:16px 0 5px;color:#64748b;font-size:.85rem;font-weight:800}.confirm-value{padding:14px;border:2px solid #cbd5e1;border-radius:12px;background:#f8fafc;font-weight:800;font-size:1.05rem;word-break:break-all}.code-value{font-size:1.3rem;letter-spacing:.04em}.bottom-nav{position:fixed;left:0;right:0;bottom:0;display:grid;grid-template-columns:repeat(3,1fr);background:#fff;border-top:1px solid #cbd5e1;padding:8px max(8px,env(safe-area-inset-right)) calc(8px + env(safe-area-inset-bottom));z-index:11}.bottom-nav button{border:0;background:#fff;padding:10px 5px;font-weight:800;color:#64748b}.bottom-nav button.active{color:var(--primary)}@media(max-width:520px){.search-row,.voice-row{grid-template-columns:1fr}.search-row .primary,.voice-btn{width:100%}.dialog-actions{flex-direction:column}.dialog-actions.split{flex-direction:row}.item{grid-template-columns:1fr auto}}
